{
    "multipart": [
        {
            "when": { "facing": "up" },
            "apply": { "model": "create_linear_motion_simulated:block/pneumatic_cylinder/link_block/block" }
        },
        {
            "when": { "facing": "down" },
            "apply": { "model": "create_linear_motion_simulated:block/pneumatic_cylinder/link_block/block", "x": 180 }
        },
        {
            "when": { "facing": "north" },
            "apply": { "model": "create_linear_motion_simulated:block/pneumatic_cylinder/link_block/block", "x": 90 }
        },
        {
            "when": { "facing": "south" },
            "apply": { "model": "create_linear_motion_simulated:block/pneumatic_cylinder/link_block/block", "x": 270 }
        },
        {
            "when": { "facing": "east" },
            "apply": { "model": "create_linear_motion_simulated:block/pneumatic_cylinder/link_block/block", "x": 90, "y": 90 }
        },
        {
            "when": { "facing": "west" },
            "apply": { "model": "create_linear_motion_simulated:block/pneumatic_cylinder/link_block/block", "x": 90, "y": 270 }
        }
    ]
}